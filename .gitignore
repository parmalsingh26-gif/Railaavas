# Dependencies
node_modules/

# Build outputs
build/
dist/
coverage/

# OS files
.DS_Store
Thumbs.db

# Logs (keep .log pattern but allow txt reports)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# SQLite database files — local only, don't push
prisma/dev.db
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# Prisma generated client (generated on postinstall)
# node_modules/@prisma already covered above

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript build cache
*.tsbuildinfo

# Vite cache
.vite/
